!artifacts/
!artifacts/.gitkeep
!artifacts/tokenizer/
!artifacts/tokenizer/.gitkeep
!artifacts/models/
!artifacts/models/.gitkeep
!artifacts/eval/
!artifacts/eval/.gitkeep

